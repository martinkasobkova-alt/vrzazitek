# Resend (https://resend.com) — odesílání objednávek z formuláře
RESEND_API_KEY=re_xxxxxxxx

# Ověřená doména v Resend, např.:
# RESEND_FROM=VR Zážitek <objednavky@vrzazitek.cz>
# Bez nastavení se použije testovací adresa Resend (omezení dle účtu).
RESEND_FROM=

# Kam doručit poptávku (výchozí: info@vrzazitek.cz)
ORDER_NOTIFY_EMAIL=info@vrzazitek.cz
